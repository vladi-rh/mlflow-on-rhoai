# MaaS (Model as a Service) Provider Configuration
# Example: MAAS_BASE_URL=https://litellm-prod.apps.maas.redhatworkshops.io/v1
# Example: MAAS_MODEL=qwen3-14b
MAAS_API_KEY=${MAAS_API_KEY}
MAAS_BASE_URL=${MAAS_BASE_URL}
MAAS_MODEL=${MAAS_MODEL}

# MLflow Configuration (RHOAI)
# Get tracking URI: DS_GW=$(oc get route data-science-gateway -n openshift-ingress -o template --template='{{.spec.host}}')
# Then: MLFLOW_TRACKING_URI=https://$DS_GW/mlflow
# Get token: export MLFLOW_TRACKING_TOKEN=$(oc whoami --show-token)
MLFLOW_TRACKING_URI=${MLFLOW_TRACKING_URI}
MLFLOW_EXPERIMENT_NAME=${MLFLOW_EXPERIMENT_NAME}
MLFLOW_WORKSPACE=${MLFLOW_WORKSPACE}
MLFLOW_TRACKING_INSECURE_TLS=${MLFLOW_TRACKING_INSECURE_TLS}
MLFLOW_TRACKING_TOKEN=${MLFLOW_TRACKING_TOKEN}

# MCP Server (Kiwi travel API - free SaaS)
# Example: MCP_SERVER_URL=https://mcp.kiwi.com
MCP_SERVER_URL=${MCP_SERVER_URL}
MCP_SERVER_ENABLED=${MCP_SERVER_ENABLED}
